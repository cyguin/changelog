{
  "name": "@cyguin/changelog-cli",
  "version": "0.1.6",
  "description": "CLI scaffolder for @cyguin/changelog",
  "keywords": ["changelog", "cli", "scaffolder", "nextjs"],
  "license": "MIT",
  "author": "Cyguin <dev@cyguin.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyguin/changelog"
  },
  "homepage": "https://github.com/cyguin/changelog#readme",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "changelog-init": "./dist/bin.js"
  },
  "exports": {
    "./templates": {
      "require": "./dist/templates/routes.cjs",
      "types": "./dist/templates/routes.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0"
  }
}
