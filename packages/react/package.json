  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0"
  }
