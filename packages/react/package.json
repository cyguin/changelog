{
  "name": "@cyguin/changelog-react",
  "version": "0.1.8",
  "type": "module",
  "description": "React components for @cyguin/changelog",
  "keywords": [
    "changelog",
    "react",
    "components",
    "nextjs"
  ],
  "license": "MIT",
  "author": "Cyguin <dev@cyguin.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyguin/changelog"
  },
  "homepage": "https://github.com/cyguin/changelog#readme",
  "bugs": {
    "url": "https://github.com/cyguin/changelog/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
